# Copy this file to ~/.config/my-opiniated-editor/bridge.env.
#
# Keep that real file private:
#   chmod 600 ~/.config/my-opiniated-editor/bridge.env

# Use 0.0.0.0 when connecting from another machine on your network.
MOE_BRIDGE_INTERFACE=0.0.0.0
MOE_BRIDGE_PORT=7682

# Use a long random value.
MOE_BRIDGE_TOKEN=replace-with-a-long-random-token
