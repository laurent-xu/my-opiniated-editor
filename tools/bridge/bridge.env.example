# Copy this file to one of:
#   ~/.config/my-opiniated-editor/bridge.env
#   tools/bridge/bridge.env
#
# Keep the real file private:
#   chmod 600 ~/.config/my-opiniated-editor/bridge.env

# Use 0.0.0.0 when connecting from another machine on your network.
MOE_BRIDGE_INTERFACE=0.0.0.0
MOE_BRIDGE_PORT=7682

# Required for network binds. Use a long random value.
MOE_BRIDGE_TOKEN=replace-with-a-long-random-token

# Optional overrides. Defaults are inferred from this repo checkout.
# MOE_BRIDGE_WORKSPACE=/home/notmyfoo/my-opiniated-editor
# MOE_BRIDGE_BAZEL=/run/current-system/sw/bin/bazelisk
# MOE_BRIDGE_BUILD=1
