#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Only lint files that the hook knows how to check. Python formatting follows
# the staged set, while C++ linting follows the full branch diff.
mapfile -t python_files < <(
  git diff --cached --name-only --diff-filter=ACMR -- '*.py'
)

status=0

if ! cpp_base="$(git merge-base HEAD origin/main 2>/dev/null)"; then
  echo "origin/main is required for C++ pre-commit checks. Fetch it first." >&2
  exit 1
fi

mapfile -t cpp_files < <(
  git diff --name-only --diff-filter=ACMR "$cpp_base" -- \
    '*.cc' '*.cpp' '*.cxx' '*.h' '*.hpp' '*.hh'
)

if [[ "${#python_files[@]}" -gt 0 ]]; then
  # Ruff is imported through Bazel/Nix, so the hook does not depend on system
  # Python or a globally installed formatter.
  echo "bazel --batch run //tools/python:pyformat -- --check ."
  if ! bazel --batch run //tools/python:pyformat -- --check .; then
    status=1
  fi
fi

if [[ "${#cpp_files[@]}" -eq 0 ]]; then
  exit "$status"
fi

# The C++ checks use LLVM tools directly. On NixOS they come from clang-tools.
if ! command -v clang-tidy >/dev/null 2>&1; then
  cat >&2 <<'EOF'
clang-tidy is required for this repo's pre-commit hook.

On NixOS, install the package that provides clang-tidy:
  clang-tools

Temporary shell:
  nix shell nixpkgs#clang-tools
EOF
  exit 1
fi

if ! command -v clang-format >/dev/null 2>&1; then
  cat >&2 <<'EOF'
clang-format is required for this repo's pre-commit hook.

On NixOS, install the package that provides clang-format:
  clang-tools

Temporary shell:
  nix shell nixpkgs#clang-tools
EOF
  exit 1
fi

# clang-tidy reads Bazel's real compile flags, include paths, and external deps
# from compile_commands.json. Refresh it before linting so we do not guess flags.
tools/bazel/refresh_compile_commands.sh

# Format every changed C++ header/source. clang-format enforces east const.
for file in "${cpp_files[@]}"; do
  [[ -f "$file" ]] || continue
  echo "clang-format --dry-run $file"
  if ! clang-format --dry-run --Werror "$file"; then
    status=1
  fi
done

# Run clang-tidy through the compile database instead of passing manual flags.
for file in "${cpp_files[@]}"; do
  [[ -f "$file" ]] || continue
  echo "clang-tidy $file"
  if ! clang-tidy "$file" --quiet -p "$repo_root"; then
    status=1
  fi
done

exit "$status"
